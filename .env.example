# DisputeDesk operator environment
# Copy to .env locally or set these in your host provider dashboard.
# Do not commit real secrets.

HOST=127.0.0.1
PORT=4173
PUBLIC_SITE_URL=https://yourdomain.com
BACKEND_URL=https://your-public-backend.example

# Protect admin-only endpoints such as /api/leads, /api/customers, and /api/operator/run.
ADMIN_TOKEN=replace-with-long-random-token
LICENSE_SECRET=replace-with-long-random-license-secret
DATA_ENCRYPTION_KEY=replace-with-long-random-data-encryption-key

# Stripe webhook signing secret from the Stripe webhook endpoint settings.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional: when set locally, ./setup-stripe.command can create Stripe products,
# monthly prices, and Payment Links through Stripe's API. Keep this server-side.
STRIPE_SECRET_KEY=sk_live_replace_me
CORE_LINK=

# Mark these true only after verifying inside Stripe Dashboard.
STRIPE_BANK_READY=false
STRIPE_IDENTITY_READY=false
STRIPE_BUSINESS_MATCH_READY=false
PAYOUT_BANK_LABEL=Chase Business account - AR Trading

# Meta Conversions API. Optional, but useful after Meta Pixel is installed.
META_PIXEL_ID=
META_ACCESS_TOKEN=

# Future official API integrations. Keep access tokens server-side only.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
REDDIT_ADS_ACCESS_TOKEN=
REDDIT_AD_ACCOUNT_ID=
